{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets//managers/oci.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/grafanaDashboards.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/talosFactory.json5#1.3.1",
  ],
  customManagers: [
    {
      // Need to copy this from managers/talosFactory since regex managers
      // cannot be targeted with matchManagers yet :(
      description: "Process Talos Factory installer images",
      customType: "regex",
      managerFilePatterns: ["kubernetes/talos\\/.*\\.ya?ml(?:\\.j2)?$/"],
      matchStrings: ["factory\\.talos\\.dev\\/[^/]+\\/[^:]+:(?<currentValue>v\\S+)"],
      datasourceTemplate: "custom.talos-factory",
      versioningTemplate: "semver",
      depNameTemplate: "siderolabs/talos",
    },
  ],
}
